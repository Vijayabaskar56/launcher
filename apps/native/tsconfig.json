{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["*"],
      "react-native-openclaw-gateway": [
        "../../packages/react-native-openclaw-gateway/src/index"
      ],
      "react-native-openclaw-gateway/*": [
        "../../packages/react-native-openclaw-gateway/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
