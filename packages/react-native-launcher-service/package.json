{
  "name": "react-native-launcher-service",
  "version": "0.0.1",
  "description": "Nitro module for app listing, adaptive icons, icon packs, and app shortcuts",
  "keywords": [
    "nitro",
    "react-native"
  ],
  "license": "MIT",
  "source": "src/index",
  "files": [
    "src",
    "react-native.config.js",
    "lib",
    "nitrogen",
    "android/build.gradle",
    "android/gradle.properties",
    "android/fix-prefab.gradle",
    "android/CMakeLists.txt",
    "android/src",
    "cpp",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "ios/**/*.swift",
    "nitro.json",
    "*.podspec",
    "README.md"
  ],
  "main": "lib/index",
  "module": "lib/index",
  "types": "lib/index.d.ts",
  "react-native": "src/index",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf android/build node_modules/**/android/build lib",
    "specs": "tsc --noEmit false && nitrogen --logLevel=\"debug\""
  },
  "devDependencies": {
    "@types/react": "^19.1.03",
    "nitrogen": "*",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-nitro-modules": "*",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  }
}
